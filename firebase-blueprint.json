{
  "entities": {
    "ChatSession": {
      "title": "ChatSession",
      "description": "Parent session document for a room's chat",
      "type": "object",
      "properties": {
        "roomNumber": {
          "type": "string"
        },
        "guestName": {
          "type": "string"
        },
        "lastMessage": {
          "type": "string"
        },
        "lastMessageTime": {
          "type": "number"
        },
        "unreadByStaff": {
          "type": "boolean"
        },
        "unreadByGuest": {
          "type": "boolean"
        },
        "chatbotDisabledUntil": {
          "type": "number"
        }
      },
      "required": [
        "roomNumber",
        "guestName",
        "lastMessage",
        "lastMessageTime",
        "unreadByStaff",
        "unreadByGuest"
      ]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "An individual message in the chat subcollection",
      "type": "object",
      "properties": {
        "text": {
          "type": "string"
        },
        "sender": {
          "type": "string",
          "enum": [
            "guest",
            "staff",
            "assistant"
          ]
        }
      },
      "required": [
        "text",
        "sender"
      ]
    }
  },
  "firestore": {
    "hotels/{hotelId}/chats/{roomNumber}": {
      "schema": "ChatSession",
      "description": "Room chat session metadata"
    },
    "hotels/{hotelId}/chats/{roomNumber}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages inside the chat session"
    }
  }
}
