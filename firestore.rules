rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validation
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    // ChatSession schema validation helper - handles merge operations and optional fields
    function isValidChatSession(data) {
      return (!data.keys().hasAny(['roomNumber']) || (data.roomNumber is string && data.roomNumber.size() <= 50))
        && (!data.keys().hasAny(['guestName']) || (data.guestName is string && data.guestName.size() <= 100))
        && (!data.keys().hasAny(['lastMessage']) || (data.lastMessage is string && data.lastMessage.size() <= 2000))
        && (!data.keys().hasAny(['lastMessageTime']) || (data.lastMessageTime is string || data.lastMessageTime is number))
        && (!data.keys().hasAny(['unreadByStaff']) || data.unreadByStaff is bool)
        && (!data.keys().hasAny(['unreadByGuest']) || data.unreadByGuest is bool)
        && (!data.keys().hasAny(['whatsapp']) || (data.whatsapp is string && data.whatsapp.size() <= 50))
        && (!data.keys().hasAny(['chatbotDisabledUntil']) || data.chatbotDisabledUntil is number);
    }

    // ChatMessage schema validation helper
    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'sender', 'timestamp'])
        && data.keys().size() <= 5
        && data.text is string
        && data.text.size() <= 2000
        && data.sender is string
        && (data.sender == 'guest' || data.sender == 'staff' || data.sender == 'assistant')
        // Enforce basic type validation on timestamp
        && (data.timestamp == null || data.timestamp is timestamp || data.timestamp is number)
        && (!data.keys().hasAny(['senderName']) || (data.senderName is string && data.senderName.size() <= 100));
    }

    // Rules for hotels/{hotelId}/chats/{roomNumber}
    match /hotels/{hotelId}/chats/{roomNumber} {
      allow get: if isValidId(hotelId) && isValidId(roomNumber);
      allow list: if isValidId(hotelId);
      allow create: if isValidId(hotelId) && isValidId(roomNumber)
                    && isValidChatSession(request.resource.data);
      allow update: if isValidId(hotelId) && isValidId(roomNumber)
                    && isValidChatSession(request.resource.data);
      allow delete: if isValidId(hotelId) && isValidId(roomNumber);

      // Rules for the messages subcollection
      match /messages/{messageId} {
        allow get: if isValidId(hotelId) && isValidId(roomNumber) && isValidId(messageId);
        allow list: if isValidId(hotelId) && isValidId(roomNumber);
        allow create: if isValidId(hotelId) && isValidId(roomNumber) && isValidId(messageId)
                      && isValidChatMessage(request.resource.data);
        allow update: if false; // Messages are immutable
        allow delete: if isValidId(hotelId) && isValidId(roomNumber) && isValidId(messageId);
      }
    }

    // Rules for hotels/{hotelId}/knowledge
    match /hotels/{hotelId}/knowledge/{knowledgeId} {
      allow get: if isValidId(hotelId) && isValidId(knowledgeId);
      allow list: if isValidId(hotelId);
      allow write: if isValidId(hotelId) && isValidId(knowledgeId);
    }

    // Rules for hotels/{hotelId}/staff
    match /hotels/{hotelId}/staff/{staffId} {
      allow get: if isValidId(hotelId) && isValidId(staffId);
      allow list: if isValidId(hotelId);
      allow write: if isValidId(hotelId) && isValidId(staffId);
    }
  }
}
